# Copy to .env and fill with real values. Do not commit .env.

# Required for pulling GHCR images from Kubernetes
CR_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional setup_rancher.ps1 defaults
ACTION=bootstrap
KUBECONFIG_PATH=rancherConfigs/main.yaml
K8S_NAMESPACE=mlops-energy
K8S_MANIFEST=rancherConfigs/slurm-stack.yaml

# Optional SLURM submit overrides
TRAIN_CMD=python train_with_energy_tracking_mlflow.py
BATCH_SIZE=64
MLFLOW_TRACKING_URI=http://mlflow:5000
GPU_SAMPLE_INTERVAL_SEC=1
ELECTRICITY_PRICE_EUR_PER_KWH=0.30
GRID_CO2_KG_PER_KWH=0.40
PUE_FACTOR=1.0
MLFLOW_LOG_JOB_ENERGY=true
MLFLOW_JOB_ENERGY_EXPERIMENT=slurm-energy
